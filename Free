-- НАСТРОЙКИ
function NovaUI:SetTransparency(enabled)
    Config.Transparency = enabled
    if self.CurrentWindow then
        local trans = enabled and 0.3 or 0
        self.CurrentWindow.Main.BackgroundTransparency = trans
        self.CurrentWindow.Sidebar.BackgroundTransparency = trans
        self.CurrentWindow.TitleBar.BackgroundTransparency = trans
        
        if self.CurrentWindow.BackgroundImage then
            self.CurrentWindow.BackgroundImage.ImageTransparency = enabled and 0.2 or 0
        end
        
        -- Обновить все вкладки
        for _, tab in pairs(self.CurrentWindow.Tabs) do
            tab.Button.BackgroundTransparency = enabled and 0.3 or 0
        end
    end
end

function NovaUI:SetTheme(themeName)
    if Config.Colors[themeName] then
        Config.Theme = themeName
        Config.AutoTextColor = false -- Отключаем авто при ручном выборе
        if self.CurrentWindow then
            UpdateTheme(self.CurrentWindow)
        end
    end
end

function NovaUI:SetBackground(imageUrl)
    Config.CustomBackground = imageUrl
    if self.CurrentWindow then
        if not self.CurrentWindow.BackgroundImage then
            -- Создаём новый фон если не было
            local bg = Instance.new("ImageLabel")
            bg.Name = "BackgroundImage"
            bg.Size = UDim2.new(1, 0, 1, 0)
            bg.BackgroundTransparency = 1
            bg.Image = imageUrl
            bg.ScaleType = Enum.ScaleType.Crop
            bg.ImageTransparency = Config.Transparency and 0.2 or 0
            bg.ZIndex = 0
            bg.Parent = self.CurrentWindow.Main
            self.CurrentWindow.BackgroundImage = bg
        else
            self.CurrentWindow.BackgroundImage.Image = imageUrl
        end
        
        -- Включаем авто-определение цвета при установке фона
        Config.AutoTextColor = true
        UpdateTheme(self.CurrentWindow)
    end
end

-- Ручной выбор цвета текста (если авто не угадал)
function NovaUI:SetTextColor(isLight)
    Config.AutoTextColor = false
    if isLight then
        CurrentColors.Text = Color3.fromRGB(255, 255, 255)
        CurrentColors.SecondaryText = Color3.fromRGB(180, 180, 180)
    else
        CurrentColors.Text = Color3.fromRGB(30, 30, 30)
        CurrentColors.SecondaryText = Color3.fromRGB(100, 100, 100)
    end
    
    if self.CurrentWindow then
        UpdateTheme(self.CurrentWindow)
    end
end

return NovaUI

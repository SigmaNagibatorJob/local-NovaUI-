-- Utils
local function Tween(obj, props, dur)
    TweenService:Create(obj, TweenInfo.new(dur or 0.3, Enum.EasingStyle.Quart), props):Play()
end

local function Corner(parent, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 6)
    c.Parent = parent
    return c
end

-- Уведомление
function NovaUI:Notify(data)
    local notifGui = Instance.new("ScreenGui")
    notifGui.Name = "NovaNotification"
    notifGui.ResetOnSpawn = false
    notifGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    notifGui.Parent = player:WaitForChild("PlayerGui")
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.fromOffset(280, 80)
    frame.Position = UDim2.new(1, -300, 1, -100)
    frame.BackgroundColor3 = CurrentColors.Background
    frame.BorderSizePixel = 0
    frame.Parent = notifGui
    
    Corner(frame, 8)
    
    -- Stroke
    local stroke = Instance.new("UIStroke")
    stroke.Color = CurrentColors.Accent
    stroke.Thickness = 2
    stroke.Parent = frame
    
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, -20, 0, 25)
    title.Position = UDim2.new(0, 10, 0, 10)
    title.BackgroundTransparency = 1
    title.Text = data.Title or "Notification"
    title.TextColor3 = CurrentColors.Accent
    title.TextSize = 14
    title.Font = Enum.Font.GothamBold
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.Parent = frame
    
    local content = Instance.new("TextLabel")
    content.Size = UDim2.new(1, -20, 0, 40)
    content.Position = UDim2.new(0, 10, 0, 35)
    content.BackgroundTransparency = 1
    content.Text = data.Content or ""
    content.TextColor3 = CurrentColors.Text
    content.TextSize = 13
    content.Font = Enum.Font.Gotham
    content.TextXAlignment = Enum.TextXAlignment.Left
    content.TextWrapped = true
    content.Parent = frame
    
    -- Анимация входа
    frame.Position = UDim2.new(1, 20, 1, -100)
    Tween(frame, {Position = UDim2.new(1, -300, 1, -100)}, 0.5)
    
    -- Авто-удаление
    task.delay(data.Duration or 5, function()
        Tween(frame, {Position = UDim2.new(1, 20, 1, -100)}, 0.5).Completed:Connect(function()
            notifGui:Destroy()
        end)
    end)
end

-- Create Window (стиль Fluent)
function NovaUI:CreateWindow(data)
    CurrentColors = Config.Colors[data.Theme or Config.Theme]
    
    local gui = Instance.new("ScreenGui")
    gui.Name = "NovaUI"
    gui.ResetOnSpawn = false
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    gui.Parent = player:WaitForChild("PlayerGui")
    
    -- Acrylic (размытие) эффект
    local acrylicFrame = nil
    if data.Acrylic or Config.Acrylic then
        acrylicFrame = Instance.new("Frame")
        acrylicFrame.Size = UDim2.new(1, 0, 1, 0)
        acrylicFrame.BackgroundColor3 = Color3.new(0, 0, 0)
        acrylicFrame.BackgroundTransparency = 0.5
        acrylicFrame.BorderSizePixel = 0
        acrylicFrame.Visible = false
        acrylicFrame.Parent = gui
        
        -- Заглушка для размытия (в Roblox нет настоящего размытия, но можно имитировать)
        local blur = Instance.new("ImageLabel")
        blur.Name = "Blur"
        blur.Size = UDim2.new(1, 0, 1, 0)
        blur.BackgroundTransparency = 1
        blur.Image = "rbxassetid://5554236805"
        blur.ImageColor3 = Color3.new(0, 0, 0)
        blur.ImageTransparency = 0.3
        blur.ScaleType = Enum.ScaleType.Slice
        blur.SliceCenter = Rect.new(23, 23, 277, 277)
        blur.Parent = acrylicFrame
    end
    
    local main = Instance.new("Frame")
    main.Size = data.Size or Config.Size
    main.Position = UDim2.new(0.5, -290, 0.5, -230)
    main.BackgroundColor3 = CurrentColors.Background
    main.BorderSizePixel = 0
    main.ClipsDescendants = true
    main.Parent = gui
    
    Corner(main, 8)
    
    -- Кастомный фон
    if Config.CustomBackground then
        local bg = Instance.new("ImageLabel")
        bg.Name = "Background"
        bg.Size = UDim2.new(1, 0, 1, 0)
        bg.BackgroundTransparency = 1
        bg.Image = Config.CustomBackground
        bg.ScaleType = Enum.ScaleType.Crop
        bg.ImageTransparency = Config.Transparency and 0.3 or 0.1
        bg.ZIndex = 0
        bg.Parent = main
    end
    
    -- Stroke
    local stroke = Instance.new("UIStroke")
    stroke.Color = CurrentColors.Border
    stroke.Thickness = 1
    stroke.Parent = main
    
    -- Title Bar
    local titleBar = Instance.new("Frame")
    titleBar.Name = "TitleBar"
    titleBar.Size = UDim2.new(1, 0, 0, 45)
    titleBar.BackgroundColor3 = CurrentColors.Sidebar
    titleBar.BorderSizePixel = 0
    titleBar.ZIndex = 2
    titleBar.Parent = main
    
    Corner(titleBar, 8)
    
    -- Заголовок
    local title = Instance.new("TextLabel")
    title.Name = "Title"
    title.Size = UDim2.new(1, -150, 0, 20)
    title.Position = UDim2.new(0, 15, 0, 8)
    title.BackgroundTransparency = 1
    title.Text = data.Title or "Nova UI"
    title.TextColor3 = CurrentColors.Text
    title.TextSize = 15
    title.Font = Enum.Font.GothamBold
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.ZIndex = 2
    title.Parent = titleBar
    
    -- SubTitle
    if data.SubTitle then
        local sub = Instance.new("TextLabel")
        sub.Name = "SubTitle"
        sub.Size = UDim2.new(1, -150, 0, 15)
        sub.Position = UDim2.new(0, 15, 0, 26)
        sub.BackgroundTransparency = 1
        sub.Text = data.SubTitle
        sub.TextColor3 = CurrentColors.SecondaryText
        sub.TextSize = 12
        sub.Font = Enum.Font.Gotham
        sub.TextXAlignment = Enum.TextXAlignment.Left
        sub.ZIndex = 2
        sub.Parent = titleBar
    end
    
    -- Кнопки управления
    local minimize = Instance.new("TextButton")
    minimize.Name = "Minimize"
    minimize.Size = UDim2.fromOffset(30, 30)
    minimize.Position = UDim2.new(1, -75, 0, 8)
    minimize.BackgroundTransparency = 1
    minimize.Text = "−"
    minimize.TextColor3 = CurrentColors.SecondaryText
    minimize.TextSize = 20
    minimize.Font = Enum.Font.Gotham
    minimize.ZIndex = 2
    minimize.Parent = titleBar
    
    local close = Instance.new("TextButton")
    close.Name = "Close"
    close.Size = UDim2.fromOffset(30, 30)
    close.Position = UDim2.new(1, -40, 0, 8)
    close.BackgroundTransparency = 1
    close.Text = "×"
    close.TextColor3 = CurrentColors.SecondaryText
    close.TextSize = 20
    close.Font = Enum.Font.Gotham
    close.ZIndex = 2
    close.Parent = titleBar
    
    -- Sidebar
    local sidebar = Instance.new("Frame")
    sidebar.Name = "Sidebar"
    sidebar.Size = UDim2.new(0, data.TabWidth or 160, 1, -45)
    sidebar.Position = UDim2.new(0, 0, 0, 45)
    sidebar.BackgroundColor3 = CurrentColors.Sidebar
    sidebar.BorderSizePixel = 0
    sidebar.ZIndex = 2
    sidebar.Parent = main
    
    local sidebarCorner = Corner(sidebar, 8)
    sidebarCorner.CornerRadius = UDim.new(0, 0) -- Убрать верхние углы
    
    local tabContainer = Instance.new("Frame")
    tabContainer.Name = "TabContainer"
    tabContainer.Size = UDim2.new(1, 0, 1, -10)
    tabContainer.Position = UDim2.new(0, 0, 0, 5)
    tabContainer.BackgroundTransparency = 1
    tabContainer.ZIndex = 2
    tabContainer.Parent = sidebar
    
    local tabList = Instance.new("UIListLayout")
    tabList.Padding = UDim.new(0, 5)
    tabList.Parent = tabContainer
    
    -- Content Area
    local contentArea = Instance.new("Frame")
    contentArea.Name = "Content"
    contentArea.Size = UDim2.new(1, -(data.TabWidth or 160), 1, -45)
    contentArea.Position = UDim2.new(0, data.TabWidth or 160, 0, 45)
    contentArea.BackgroundTransparency = 1
    contentArea.ZIndex = 2
    contentArea.Parent = main
    
    -- Drag
    local dragging, dragStart, startPos
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = main.Position
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    
    -- Minimize
    local minimized = false
    minimize.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then
            Tween(main, {Size = UDim2.new(0, main.Size.X.Offset, 0, 45)})
            contentArea.Visible = false
            sidebar.Visible = false
        else
            Tween(main, {Size = data.Size or Config.Size})
            task.delay(0.3, function()
                contentArea.Visible = true
                sidebar.Visible = true
            end)
        end
    end)
    
    -- Close
    close.MouseEnter:Connect(function() Tween(close, {TextColor3 = Color3.fromRGB(255, 100, 100)}) end)
    close.MouseLeave:Connect(function() Tween(close, {TextColor3 = CurrentColors.SecondaryText}) end)
    close.MouseButton1Click:Connect(function()
        Tween(main, {Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0.5, 0)}, 0.3).Completed:Connect(function()
            gui:Destroy()
            NovaUI.Unloaded = true
        end)
    end)
    
    local Window = {
        Gui = gui,
        Main = main,
        Sidebar = sidebar,
        TabContainer = tabContainer,
        Content = contentArea,
        Tabs = {},
        ActiveTab = nil,
        Options = Options
    }
    
    table.insert(Windows, Window)
    NovaUI.CurrentWindow = Window
    
    -- Minimize Key
    if data.MinimizeKey or Config.MinimizeKey then
        UserInputService.InputBegan:Connect(function(input)
            if input.KeyCode == (data.MinimizeKey or Config.MinimizeKey) then
                minimize.MouseButton1Click:Fire()
            end
        end)
    end
    
    return Window
end

-- Add Tab (Fluent стиль)
function NovaUI:AddTab(data)
    local window = NovaUI.CurrentWindow
    if not window then return end
    
    local btn = Instance.new("TextButton")
    btn.Name = data.Title .. "Tab"
    btn.Size = UDim2.new(1, -10, 0, 32)
    btn.Position = UDim2.new(0, 5, 0, 0)
    btn.BackgroundColor3 = CurrentColors.Sidebar
    btn.BorderSizePixel = 0
    btn.Text = ""
    btn.AutoButtonColor = false
    btn.ZIndex = 2
    btn.Parent = window.TabContainer
    
    Corner(btn, 6)
    
    -- Иконка (Lucide стиль)
    if data.Icon and data.Icon ~= "" then
        local icon = Instance.new("ImageLabel")
        icon.Name = "Icon"
        icon.Size = UDim2.fromOffset(18, 18)
        icon.Position = UDim2.new(0, 10, 0.5, -9)
        icon.BackgroundTransparency = 1
        -- Здесь можно использовать rbxassetid для иконок
        icon.Image = "rbxassetid://3926305904" -- Заглушка
        icon.ImageColor3 = CurrentColors.SecondaryText
        icon.ZIndex = 2
        icon.Parent = btn
    end
    
    local txt = Instance.new("TextLabel")
    txt.Name = "Text"
    txt.Size = UDim2.new(1, data.Icon and -40 or -20, 1, 0)
    txt.Position = UDim2.new(0, data.Icon and 35 or 15, 0, 0)
    txt.BackgroundTransparency = 1
    txt.Text = data.Title
    txt.TextColor3 = CurrentColors.SecondaryText
    txt.TextSize = 13
    txt.Font = Enum.Font.GothamMedium
    txt.TextXAlignment = Enum.TextXAlignment.Left
    txt.ZIndex = 2
    txt.Parent = btn
    
    -- Индикатор активной вкладки
    local indicator = Instance.new("Frame")
    indicator.Name = "Indicator"
    indicator.Size = UDim2.new(0, 3, 0, 0)
    indicator.Position = UDim2.new(0, 0, 0.5, 0)
    indicator.BackgroundColor3 = CurrentColors.Accent
    indicator.BorderSizePixel = 0
    indicator.ZIndex = 2
    indicator.Parent = btn
    
    Corner(indicator, 2)
    
    -- Content
    local content = Instance.new("ScrollingFrame")
    content.Name = data.Title .. "Content"
    content.Size = UDim2.new(1, 0, 1, 0)
    content.BackgroundTransparency = 1
    content.BorderSizePixel = 0
    content.ScrollBarThickness = 4
    content.ScrollBarImageColor3 = CurrentColors.Accent
    content.AutomaticCanvasSize = Enum.AutomaticSize.Y
    content.Visible = false
    content.ZIndex = 2
    content.Parent = window.Content
    
    local pad = Instance.new("UIPadding")
    pad.PaddingLeft = UDim.new(0, 15)
    pad.PaddingRight = UDim.new(0, 15)
    pad.PaddingTop = UDim.new(0, 15)
    pad.PaddingBottom = UDim.new(0, 15)
    pad.Parent = content
    
    local list = Instance.new("UIListLayout")
    list.Padding = UDim.new(0, 10)
    list.Parent = content
    
    local tab = {
        Button = btn,
        Content = content,
        Title = data.Title,
        Active = false,
        Elements = {}
    }
    
    -- Hover
    btn.MouseEnter:Connect(function()
        if not tab.Active then Tween(btn, {BackgroundColor3 = CurrentColors.Hover}) end
    end)
    
    btn.MouseLeave:Connect(function()
        if not tab.Active then Tween(btn, {BackgroundColor3 = CurrentColors.Sidebar}) end
    end)
    
    -- Click
    btn.MouseButton1Click:Connect(function()
        if window.ActiveTab then
            local prev = window.ActiveTab
            prev.Active = false
            Tween(prev.Button, {BackgroundColor3 = CurrentColors.Sidebar})
            prev.Button.Indicator.Size = UDim2.new(0, 3, 0, 0)
            prev.Button.Text.TextColor3 = CurrentColors.SecondaryText
            prev.Content.Visible = false
        end
        
        tab.Active = true
        window.ActiveTab = tab
        Tween(btn, {BackgroundColor3 = CurrentColors.Selected})
        Tween(indicator, {Size = UDim2.new(0, 3, 0, 20)})
        txt.TextColor3 = CurrentColors.Text
        content.Visible = true
        content.Position = UDim2.new(0, 10, 0, 0)
        Tween(content, {Position = UDim2.new(0, 0, 0, 0)})
    end)
    
    table.insert(window.Tabs, tab)
    
    -- Auto-select first
    if #window.Tabs == 1 then
        task.delay(0.1, function()
            btn.MouseButton1Click:Fire()
        end)
    end
    
    -- Методы для добавления элементов
    function tab:AddParagraph(data)
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, 0, 0, 50)
        frame.BackgroundTransparency = 1
        frame.Parent = self.Content
        
        local title = Instance.new("TextLabel")
        title.Size = UDim2.new(1, 0, 0, 20)
        title.BackgroundTransparency = 1
        title.Text = data.Title or ""
        title.TextColor3 = CurrentColors.Text
        title.TextSize = 14
        title.Font = Enum.Font.GothamBold
        title.TextXAlignment = Enum.TextXAlignment.Left
        title.Parent = frame
        
        local content = Instance.new("TextLabel")
        content.Size = UDim2.new(1, 0, 0, 30)
        content.Position = UDim2.new(0, 0, 0, 20)
        content.BackgroundTransparency = 1
        content.Text = data.Content or ""
        content.TextColor3 = CurrentColors.SecondaryText
        content.TextSize = 12
        content.Font = Enum.Font.Gotham
        content.TextXAlignment = Enum.TextXAlignment.Left
        content.TextWrapped = true
        content.Parent = frame
        
        return frame
    end
    
    function tab:AddButton(data)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 35)
        btn.BackgroundColor3 = CurrentColors.Hover
        btn.BorderSizePixel = 0
        btn.Text = ""
        btn.AutoButtonColor = false
        btn.Parent = self.Content
        
        Corner(btn, 6)
        
        local title = Instance.new("TextLabel")
        title.Size = UDim2.new(1, -20, 0, 20)
        title.Position = UDim2.new(0, 10, 0, 8)
        title.BackgroundTransparency = 1
        title.Text = data.Title or "Button"
        title.TextColor3 = CurrentColors.Text
        title.TextSize = 13
        title.Font = Enum.Font.GothamMedium
        title.TextXAlignment = Enum.TextXAlignment.Left
        title.Parent = btn
        
        if data.Description then
            local desc = Instance.new("TextLabel")
            desc.Size = UDim2.new(1, -20, 0, 15)
            desc.Position = UDim2.new(0, 10, 0, 25)
            desc.BackgroundTransparency = 1
            desc.Text = data.Description
            desc.TextColor3 = CurrentColors.SecondaryText
            desc.TextSize = 11
            desc.Font = Enum.Font.Gotham
            desc.TextXAlignment = Enum.TextXAlignment.Left
            desc.Parent = btn
            btn.Size = UDim2.new(1, 0, 0, 45)
        end
        
        btn.MouseEnter:Connect(function() Tween(btn, {BackgroundColor3 = CurrentColors.Selected}) end)
        btn.MouseLeave:Connect(function() Tween(btn, {BackgroundColor3 = CurrentColors.Hover}) end)
        btn.MouseButton1Click:Connect(function()
            if data.Callback then data.Callback() end
        end)
        
        return btn
    end
    
    function tab:AddToggle(key, data)
        Options[key] = {Value = data.Default or false}
        
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, 0, 0, 40)
        frame.BackgroundColor3 = CurrentColors.Hover
        frame.BorderSizePixel = 0
        frame.Parent = self.Content
        
        Corner(frame, 6)
        
        local title = Instance.new("TextLabel")
        title.Size = UDim2.new(1, -70, 1, 0)
        title.Position = UDim2.new(0, 12, 0, 0)
        title.BackgroundTransparency = 1
        title.Text = data.Title or "Toggle"
        title.TextColor3 = CurrentColors.Text
        title.TextSize = 13
        title.Font = Enum.Font.GothamMedium
        title.TextXAlignment = Enum.TextXAlignment.Left
        title.Parent = frame
        
        local toggleBtn = Instance.new("TextButton")
        toggleBtn.Size = UDim2.fromOffset(44, 24)
        toggleBtn.Position = UDim2.new(1, -56, 0.5, -12)
        toggleBtn.BackgroundColor3 = data.Default and CurrentColors.Accent or CurrentColors.Border
        toggleBtn.BorderSizePixel = 0
        toggleBtn.Text = ""
        toggleBtn.AutoButtonColor = false
        toggleBtn.Parent = frame
        
        Corner(toggleBtn, 12)
        
        local circle = Instance.new("Frame")
        circle.Size = UDim2.fromOffset(18, 18)
        circle.Position = data.Default and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)
        circle.BackgroundColor3 = Color3.new(1, 1, 1)
        circle.BorderSizePixel = 0
        circle.Parent = toggleBtn
        
        Corner(circle, 9)
        
        local function updateState()
            Options[key].Value = not Options[key].Value
            Tween(toggleBtn, {BackgroundColor3 = Options[key].Value and CurrentColors.Accent or CurrentColors.Border})
            Tween(circle, {Position = Options[key].Value and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)})
            if data.Callback then data.Callback(Options[key].Value) end
        end
        
        toggleBtn.MouseButton1Click:Connect(updateState)
        frame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                updateState()
            end
        end)
        
        -- Методы
        function Options[key]:OnChanged(callback)
            self.ChangedCallback = callback
        end
        
        function Options[key]:SetValue(val)
            if self.Value ~= val then
                self.Value = val
                Tween(toggleBtn, {BackgroundColor3 = val and CurrentColors.Accent or CurrentColors.Border})
                Tween(circle, {Position = val and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)})
                if self.ChangedCallback then self.ChangedCallback(val) end
            end
        end
        
        return Options[key]
    end
    
    function tab:AddSlider(key, data)
        Options[key] = {Value = data.Default or data.Min or 0}
        
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, 0, 0, 65)
        frame.BackgroundColor3 = CurrentColors.Hover
        frame.BorderSizePixel = 0
        frame.Parent = self.Content
        
        Corner(frame, 6)
        
        local title = Instance.new("TextLabel")
        title.Size = UDim2.new(1, -60, 0, 20)
        title.Position = UDim2.new(0, 12, 0, 8)
        title.BackgroundTransparency = 1
        title.Text = data.Title or "Slider"
        title.TextColor3 = CurrentColors.Text
        title.TextSize = 13
        title.Font = Enum.Font.GothamMedium
        title.TextXAlignment = Enum.TextXAlignment.Left
        title.Parent = frame
        
        local valLabel = Instance.new("TextLabel")
        valLabel.Size = UDim2.new(0, 50, 0, 20)
        valLabel.Position = UDim2.new(1, -62, 0, 8)
        valLabel.BackgroundTransparency = 1
        valLabel.Text = tostring(data.Default or 0)
        valLabel.TextColor3 = CurrentColors.Accent
        valLabel.TextSize = 13
        valLabel.Font = Enum.Font.GothamBold
        valLabel.TextXAlignment = Enum.TextXAlignment.Right
        valLabel.Parent = frame
        
        local desc = nil
        if data.Description then
            desc = Instance.new("TextLabel")
            desc.Size = UDim2.new(1, -20, 0, 15)
            desc.Position = UDim2.new(0, 12, 0, 25)
            desc.BackgroundTransparency = 1
            desc.Text = data.Description
            desc.TextColor3 = CurrentColors.SecondaryText
            desc.TextSize = 11
            desc.Font = Enum.Font.Gotham
            desc.TextXAlignment = Enum.TextXAlignment.Left
            desc.Parent = frame
        end
        
        local sliderY = desc and 42 or 35
        
        local bg = Instance.new("Frame")
        bg.Size = UDim2.new(1, -24, 0, 6)
        bg.Position = UDim2.new(0, 12, 0, sliderY)
        bg.BackgroundColor3 = CurrentColors.Border
        bg.BorderSizePixel = 0
        bg.Parent = frame
        
        Corner(bg, 3)
        
        local fill = Instance.new("Frame")
        local defaultPercent = (data.Default - data.Min) / (data.Max - data.Min)
        fill.Size = UDim2.new(defaultPercent, 0, 1, 0)
        fill.BackgroundColor3 = CurrentColors.Accent
        fill.BorderSizePixel = 0
        fill.Parent = bg
        
        Corner(fill, 3)
        
        local knob = Instance.new("Frame")
        knob.Size = UDim2.fromOffset(16, 16)
        knob.Position = UDim2.new(defaultPercent, -8, 0.5, -8)
        knob.BackgroundColor3 = Color3.new(1, 1, 1)
        knob.BorderSizePixel = 0
        knob.Parent = bg
        
        Corner(knob, 8)
        
        local dragging = false
        
        local function update(input)
            local pos = math.clamp((input.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
            local value = data.Min + (data.Max - data.Min) * pos
            
            if data.Rounding then
                value = math.round(value * (10 ^ data.Rounding)) / (10 ^ data.Rounding)
            else
                value = math.floor(value)
            end
            
            fill.Size = UDim2.new(pos, 0, 1, 0)
            knob.Position = UDim2.new(pos, -8, 0.5, -8)
            valLabel.Text = tostring(value)
            Options[key].Value = value
            
            if data.Callback then data.Callback(value) end
            if Options[key].ChangedCallback then Options[key].ChangedCallback(value) end
        end
        
        bg.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                update(input)
            end
        end)
        
        UserInputService.InputChanged:Connect(function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                update(input)
            end
        end)
        
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
        
        -- Методы
        function Options[key]:OnChanged(callback)
            self.ChangedCallback = callback
        end
        
        function Options[key]:SetValue(val)
            local pos = (val - data.Min) / (data.Max - data.Min)
            fill.Size = UDim2.new(pos, 0, 1, 0)
            knob.Position = UDim2.new(pos, -8, 0.5, -8)
            valLabel.Text = tostring(val)
            self.Value = val
            if self.ChangedCallback then self.ChangedCallback(val) end
        end
        
        return Options[key]
    end
    
    function tab:AddDropdown(key, data)
        Options[key] = {Value = data.Default or (data.Multi and {} or (data.Values and data.Values[1] or ""))}
        
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, 0, 0, 40)
        frame.BackgroundColor3 = CurrentColors.Hover
        frame.BorderSizePixel = 0
        frame.ClipsDescendants = true
        frame.Parent = self.Content
        
        Corner(frame, 6)
        
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 40)
        btn.BackgroundTransparency = 1
        btn.Text = ""
        btn.Parent = frame
        
        local title = Instance.new("TextLabel")
        title.Size = UDim2.new(1, -50, 1, 0)
        title.Position = UDim2.new(0, 12, 0, 0)
        title.BackgroundTransparency = 1
        title.Text = data.Title or "Dropdown"
        title.TextColor3 = CurrentColors.Text
        title.TextSize = 13
        title.Font = Enum.Font.GothamMedium
        title.TextXAlignment = Enum.TextXAlignment.Left
        title.Parent = btn
        
        local selected = Instance.new("TextLabel")
        selected.Name = "Selected"
        selected.Size = UDim2.new(0, 120, 1, 0)
        selected.Position = UDim2.new(1, -140, 0, 0)
        selected.BackgroundTransparency = 1
        selected.Text = data.Multi and "Select..." or (data.Default or (data.Values and data.Values[1] or "Select..."))
        selected.TextColor3 = CurrentColors.SecondaryText
        selected.TextSize = 12
        selected.Font = Enum.Font.Gotham
        selected.TextXAlignment = Enum.TextXAlignment.Right
        selected.Parent = btn
        
        local arrow = Instance.new("TextLabel")
        arrow.Size = UDim2.fromOffset(20, 40)
        arrow.Position = UDim2.new(1, -25, 0, 0)
        arrow.BackgroundTransparency = 1
        arrow.Text = "▼"
        arrow.TextColor3 = CurrentColors.SecondaryText
        arrow.TextSize = 12
        arrow.Font = Enum.Font.Gotham
        arrow.Parent = btn
        
        local optsFrame = Instance.new("Frame")
        optsFrame.Size = UDim2.new(1, 0, 0, #data.Values * 32)
        optsFrame.Position = UDim2.new(0, 0, 0, 40)
        optsFrame.BackgroundColor3 = CurrentColors.Hover
        optsFrame.BorderSizePixel = 0
        optsFrame.Visible = false
        optsFrame.Parent = frame
        
        local expanded = false
        local selectedValues = data.Multi and {} or nil
        
        if data.Multi and data.Default then
            for k, v in pairs(data.Default) do
                selectedValues[k] = v
            end
        end
        
        for i, val in ipairs(data.Values or {}) do
            local optBtn = Instance.new("TextButton")
            optBtn.Size = UDim2.new(1, 0, 0, 32)
            optBtn.Position = UDim2.new(0, 0, 0, (i-1) * 32)
            optBtn.BackgroundTransparency = 1
            optBtn.Text = val
            optBtn.TextColor3 = CurrentColors.SecondaryText
            optBtn.TextSize = 12
            optBtn.Font = Enum.Font.Gotham
            optBtn.Parent = optsFrame
            
            optBtn.MouseEnter:Connect(function()
                Tween(optBtn, {BackgroundTransparency = 0.9, BackgroundColor3 = CurrentColors.Accent})
            end)
            
            optBtn.MouseLeave:Connect(function()
                Tween(optBtn, {BackgroundTransparency = 1})
            end)
            
            optBtn.MouseButton1Click:Connect(function()
                if data.Multi then
                    selectedValues[val] = not selectedValues[val]
                    -- Обновить текст
                    local vals = {}
                    for k, v in pairs(selectedValues) do
                        if v then table.insert(vals, k) end
                    end
                    selected.Text = #vals > 0 and table.concat(vals, ", ") or "Select..."
                    Options[key].Value = selectedValues
                else
                    selected.Text = val
                    Options[key].Value = val
                    expanded = false
                    Tween(frame, {Size = UDim2.new(1, 0, 0, 40)})
                    Tween(arrow, {Rotation = 0})
                    task.delay(0.2, function() optsFrame.Visible = false end)
                end
                
                if data.Callback then data.Callback(Options[key].Value) end
                if Options[key].ChangedCallback then Options[key].ChangedCallback(Options[key].Value) end
            end)
        end
        
        btn.MouseButton1Click:Connect(function()
            expanded = not expanded
            if expanded then
                optsFrame.Visible = true
                Tween(frame, {Size = UDim2.new(1, 0, 0, 40 + #data.Values * 32)})
                Tween(arrow, {Rotation = 180})
            else
                Tween(frame, {Size = UDim2.new(1, 0, 0, 40)})
                Tween(arrow, {Rotation = 0})
                task.delay(0.2, function() optsFrame.Visible = false end)
            end
        end)
        
        -- Методы
        function Options[key]:OnChanged(callback)
            self.ChangedCallback = callback
        end
        
        function Options[key]:SetValue(val)
            if data.Multi then
                selectedValues = val
                local vals = {}
                for k, v in pairs(val) do
                    if v then table.insert(vals, k) end
                end
                selected.Text = #vals > 0 and table.concat(vals, ", ") or "Select..."
            else
                selected.Text = val
            end
            self.Value = val
            if self.ChangedCallback then self.ChangedCallback(val) end
        end
        
        return Options[key]
    end
    
    function tab:AddInput(key, data)
        Options[key] = {Value = data.Default or ""}
        
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, 0, 0, 65)
        frame.BackgroundColor3 = CurrentColors.Hover
        frame.BorderSizePixel = 0
        frame.Parent = self.Content
        
        Corner(frame, 6)
        
        local title = Instance.new("TextLabel")
        title.Size = UDim2.new(1, -20, 0, 20)
        title.Position = UDim2.new(0, 12, 0, 8)
        title.BackgroundTransparency = 1
        title.Text = data.Title or "Input"
        title.TextColor3 = CurrentColors.Text
        title.TextSize = 13
        title.Font = Enum.Font.GothamMedium
        title.TextXAlignment = Enum.TextXAlignment.Left
        title.Parent = frame
        
        local box = Instance.new("TextBox")
        box.Size = UDim2.new(1, -24, 0, 30)
        box.Position = UDim2.new(0, 12, 0, 30)
        box.BackgroundColor3 = CurrentColors.Background
        box.BorderSizePixel = 0
        box.Text = data.Default or ""
        box.PlaceholderText = data.Placeholder or "Enter text..."
        box.TextColor3 = CurrentColors.Text
        box.PlaceholderColor3 = CurrentColors.SecondaryText
        box.TextSize = 12
        box.Font = Enum.Font.Gotham
        box.ClearTextOnFocus = false
        box.Parent = frame
        
        Corner(box, 4)
        
        box.FocusLost:Connect(function()
            Options[key].Value = box.Text
            if data.Callback then data.Callback(box.Text) end
            if Options[key].ChangedCallback then Options[key].ChangedCallback(box.Text) end
        end)
        
        box:GetPropertyChangedSignal("Text"):Connect(function()
            Options[key].Value = box.Text
            if not data.Finished and Options[key].ChangedCallback then
                Options[key].ChangedCallback(box.Text)
            end
        end)
        
        -- Методы
        function Options[key]:OnChanged(callback)
            self.ChangedCallback = callback
        end
        
        function Options[key]:SetValue(val)
            box.Text = val
            self.Value = val
        end
        
        return Options[key]
    end
    
    return tab
end

-- Настройки
function NovaUI:SetTheme(theme)
    if Config.Colors[theme] then
        Config.Theme = theme
        CurrentColors = Config.Colors[theme]
        -- Обновить все окна
        for _, window in pairs(Windows) do
            Tween(window.Main, {BackgroundColor3 = CurrentColors.Background})
            Tween(window.Sidebar, {BackgroundColor3 = CurrentColors.Sidebar})
            Tween(window.TitleBar, {BackgroundColor3 = CurrentColors.Sidebar})
        end
    end
end

function NovaUI:SetTransparency(enabled)
    Config.Transparency = enabled
    -- Применить к текущему окну
    if self.CurrentWindow then
        local trans = enabled and 0.3 or 0
        self.CurrentWindow.Main.BackgroundTransparency = trans
    end
end

function NovaUI:SetBackground(url)
    Config.CustomBackground = url
    if self.CurrentWindow then
        local bg = self.CurrentWindow.Main:FindFirstChild("Background")
        if not bg then
            bg = Instance.new("ImageLabel")
            bg.Name = "Background"
            bg.Size = UDim2.new(1, 0, 1, 0)
            bg.ZIndex = 0
            bg.Parent = self.CurrentWindow.Main
        end
        bg.Image = url
        bg.ImageTransparency = Config.Transparency and 0.3 or 0.1
    end
end

function NovaUI:SelectTab(index)
    local window = self.CurrentWindow
    if window and window.Tabs[index] then
        window.Tabs[index].Button.MouseButton1Click:Fire()
    end
end

function NovaUI:Destroy()
    if self.CurrentWindow then
        self.CurrentWindow.Gui:Destroy()
        self.Unloaded = true
    end
end

-- Диалог (Fluent стиль)
function NovaUI:Dialog(data)
    local dialogGui = Instance.new("ScreenGui")
    dialogGui.Name = "NovaDialog"
    dialogGui.ResetOnSpawn = false
    dialogGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    dialogGui.Parent = player:WaitForChild("PlayerGui")
    
    local overlay = Instance.new("Frame")
    overlay.Size = UDim2.new(1, 0, 1, 0)
    overlay.BackgroundColor3 = Color3.new(0, 0, 0)
    overlay.BackgroundTransparency = 0.5
    overlay.BorderSizePixel = 0
    overlay.Parent = dialogGui
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.fromOffset(400, 200)
    frame.Position = UDim2.new(0.5, -200, 0.5, -100)
    frame.BackgroundColor3 = CurrentColors.Background
    frame.BorderSizePixel = 0
    frame.Parent = dialogGui
    
    Corner(frame, 12)
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = CurrentColors.Border
    stroke.Thickness = 2
    stroke.Parent = frame
    
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, -40, 0, 30)
    title.Position = UDim2.new(0, 20, 0, 20)
    title.BackgroundTransparency = 1
    title.Text = data.Title or "Dialog"
    title.TextColor3 = CurrentColors.Text
    title.TextSize = 18
    title.Font = Enum.Font.GothamBold
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.Parent = frame
    
    local content = Instance.new("TextLabel")
    content.Size = UDim2.new(1, -40, 0, 80)
    content.Position = UDim2.new(0, 20, 0, 60)
    content.BackgroundTransparency = 1
    content.Text = data.Content or ""
    content.TextColor3 = CurrentColors.SecondaryText
    content.TextSize = 14
    content.Font = Enum.Font.Gotham
    content.TextWrapped = true
    content.TextXAlignment = Enum.TextXAlignment.Left
    content.TextYAlignment = Enum.TextYAlignment.Top
    content.Parent = frame
    
    local buttonsFrame = Instance.new("Frame")
    buttonsFrame.Size = UDim2.new(1, -40, 0, 40)
    buttonsFrame.Position = UDim2.new(0, 20, 1, -60)
    buttonsFrame.BackgroundTransparency = 1
    buttonsFrame.Parent = frame
    
    local btnList = Instance.new("UIListLayout")
    btnList.FillDirection = Enum.FillDirection.Horizontal
    btnList.HorizontalAlignment = Enum.HorizontalAlignment.Right
    btnList.Padding = UDim.new(0, 10)
    btnList.Parent = buttonsFrame
    
    for i, btnData in ipairs(data.Buttons or {}) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.fromOffset(100, 35)
        btn.BackgroundColor3 = i == 1 and CurrentColors.Accent or CurrentColors.Hover
        btn.BorderSizePixel = 0
        btn.Text = btnData.Title or "Button"
        btn.TextColor3 = i == 1 and Color3.new(1, 1, 1) or CurrentColors.Text
        btn.TextSize = 13
        btn.Font = Enum.Font.GothamSemibold
        btn.Parent = buttonsFrame
        
        Corner(btn, 6)
        
        btn.MouseEnter:Connect(function()
            if i ~= 1 then Tween(btn, {BackgroundColor3 = CurrentColors.Selected}) end
        end)
        
        btn.MouseLeave:Connect(function()
            if i ~= 1 then Tween(btn, {BackgroundColor3 = CurrentColors.Hover}) end
        end)
        
        btn.MouseButton1Click:Connect(function()
            if btnData.Callback then btnData.Callback() end
            Tween(overlay, {BackgroundTransparency = 1})
            Tween(frame, {Position = UDim2.new(0.5, -200, 0.5, -50), Size = UDim2.fromOffset(400, 0)}).Completed:Connect(function()
                dialogGui:Destroy()
            end)
        end)
    end
    
    -- Анимация входа
    frame.Size = UDim2.fromOffset(400, 0)
    Tween(frame, {Size = UDim2.fromOffset(400, 200)})
end

return NovaUI

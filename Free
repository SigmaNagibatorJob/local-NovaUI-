-- Services
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- Config
local Config = {
    Size = UDim2.new(0, 500, 0, 400),
    Transparency = false,
    Theme = "Dark",
    CustomBackground = nil,
    AutoTextColor = true, -- Авто-определение цвета текста
    Colors = {
        Dark = {
            Background = Color3.fromRGB(25, 25, 25),
            Sidebar = Color3.fromRGB(30, 30, 30),
            Accent = Color3.fromRGB(0, 120, 215),
            Text = Color3.fromRGB(255, 255, 255),
            SecondaryText = Color3.fromRGB(180, 180, 180),
            Hover = Color3.fromRGB(45, 45, 45),
            Selected = Color3.fromRGB(55, 55, 55),
            Border = Color3.fromRGB(60, 60, 60)
        },
        Light = {
            Background = Color3.fromRGB(245, 245, 245),
            Sidebar = Color3.fromRGB(235, 235, 235),
            Accent = Color3.fromRGB(0, 120, 215),
            Text = Color3.fromRGB(30, 30, 30),
            SecondaryText = Color3.fromRGB(100, 100, 100),
            Hover = Color3.fromRGB(220, 220, 220),

local CurrentColors = Config.Colors.Dark

-- Utils
local function Tween(obj, props, dur)
    game:GetService("TweenService"):Create(obj, TweenInfo.new(dur or 0.3, Enum.EasingStyle.Quart), props):Play()
end

local function Corner(parent, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 6)
    c.Parent = parent
    return c
end

-- Определение яркости цвета (для контраста текста)
local function GetBrightness(color)
    return (color.R * 0.299 + color.G * 0.587 + color.B * 0.114)
end

-- Авто-выбор цвета текста на основе фона
local function GetContrastTextColor(bgColor)
    local brightness = GetBrightness(bgColor)
    if brightness > 0.5 then
        return Color3.fromRGB(30, 30, 30) -- Тёмный текст для светлого фона
    else
        return Color3.fromRGB(255, 255, 255) -- Белый текст для тёмного фона
    end
end

-- Обновление темы
local function UpdateTheme(window)
    CurrentColors = Config.Colors[Config.Theme]
    
    -- Если есть кастомный фон и авто-цвет вкл, определяем цвет текста по фону
    if Config.CustomBackground and Config.AutoTextColor and window.BackgroundImage then
        -- Проверяем средний цвет фона (упрощённо)
        local avgBrightness = 0.5 -- По умолчанию средний
        
        -- Для raw.githubusercontent используем предустановленные значения
        -- или определяем по прозрачности фона
        if Config.Transparency then
            avgBrightness = 0.3 -- Тёмный полупрозрачный
        end
        
        local textColor = GetContrastTextColor(Color3.new(avgBrightness, avgBrightness, avgBrightness))
        local secondaryText = textColor == Color3.fromRGB(255, 255, 255) and Color3.fromRGB(180, 180, 180) or Color3.fromRGB(100, 100, 100)
        
        CurrentColors.Text = textColor
        CurrentColors.SecondaryText = secondaryText
    end
    
    Tween(window.Main, {BackgroundColor3 = CurrentColors.Background})
    Tween(window.Sidebar, {BackgroundColor3 = CurrentColors.Sidebar})
    
    for _, tab in pairs(window.Tabs) do
        local txt = tab.Button:FindFirstChild("Text")
        if txt then
            txt.TextColor3 = tab.Active and CurrentColors.Text or CurrentColors.SecondaryText
        end
    end
end

-- Select Tab
local function SelectTab(window, tab)
    if window.ActiveTab == tab then return end
    
    if window.ActiveTab then
        local prev = window.ActiveTab
        prev.Active = false
        Tween(prev.Button, {BackgroundColor3 = CurrentColors.Sidebar})
        prev.Button.Indicator.Size = UDim2.new(0, 3, 0, 0)
        
        local prevText = prev.Button:FindFirstChild("Text")
        if prevText then prevText.TextColor3 = CurrentColors.SecondaryText end
        
        if prev.Button:FindFirstChild("Icon") then
            prev.Button.Icon.ImageColor3 = CurrentColors.SecondaryText
        end
        prev.Content.Visible = false
    end
    
    tab.Active = true
    window.ActiveTab = tab
    tab.Content.Visible = true
    Tween(tab.Button, {BackgroundColor3 = CurrentColors.Selected})
    Tween(tab.Button.Indicator, {Size = UDim2.new(0, 3, 0, 20)})
    
    local tabText = tab.Button:FindFirstChild("Text")
    if tabText then tabText.TextColor3 = CurrentColors.Text end
    
    if tab.Button:FindFirstChild("Icon") then
        tab.Button.Icon.ImageColor3 = CurrentColors.Accent
    end
    tab.Content.Position = UDim2.new(0, 10, 0, 0)
    Tween(tab.Content, {Position = UDim2.new(0, 0, 0, 0)})
end

-- Create Window
function NovaUI:CreateWindow(title)
    CurrentColors = Config.Colors[Config.Theme]
    
    local gui = Instance.new("ScreenGui")
    gui.Name = "NovaUI"
    gui.ResetOnSpawn = false
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    gui.Parent = player:WaitForChild("PlayerGui")
    
    local main = Instance.new("Frame")
    main.Size = Config.Size
    main.Position = UDim2.new(0.5, -250, 0.5, -200)
    main.BackgroundColor3 = CurrentColors.Background
    main.BorderSizePixel = 0
    main.ClipsDescendants = true
    main.Parent = gui
    
    -- Кастомный фон с raw.githubusercontent.com
    local bgImage = nil
    if Config.CustomBackground then
        bgImage = Instance.new("ImageLabel")
        bgImage.Name = "BackgroundImage"
        bgImage.Size = UDim2.new(1, 0, 1, 0)
        bgImage.BackgroundTransparency = 1
        bgImage.Image = Config.CustomBackground -- Поддержка любых URL включая raw.githubusercontent
        bgImage.ScaleType = Enum.ScaleType.Crop
        bgImage.ImageTransparency = Config.Transparency and 0.2 or 0
        bgImage.ZIndex = 0
        bgImage.Parent = main
        
        -- Если фон загружен, пробуем определить его яркость
        bgImage.Loaded:Connect(function()
            if Config.AutoTextColor then
                -- Упрощённая логика: предполагаем что пользователь знает что делает
                -- или используем ручной выбор темы
                UpdateTheme(NovaUI.CurrentWindow)
            end
        end)
    end
    
    if Config.Transparency then
        main.BackgroundTransparency = 0.3
    end
    
    Corner(main, 8)
    
    local shadow = Instance.new("ImageLabel")
    shadow.BackgroundTransparency = 1
    shadow.Image = "rbxassetid://5554236805"
    shadow.ImageColor3 = Color3.new(0, 0, 0)
    shadow.ImageTransparency = 0.6
    shadow.ScaleType = Enum.ScaleType.Slice
    shadow.SliceCenter = Rect.new(23, 23, 277, 277)
    shadow.Size = UDim2.new(1, 40, 1, 40)
    shadow.Position = UDim2.new(0, -20, 0, -20)
    shadow.ZIndex = -1
    shadow.Parent = main
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = CurrentColors.Border
    stroke.Parent = main
    
    main.Size = UDim2.new(0, 0, 0, 0)
    main.Position = UDim2.new(0.5, 0, 0.5, 0)
    Tween(main, {Size = Config.Size, Position = UDim2.new(0.5, -250, 0.5, -200)}, 0.5)
    
    local titleBar = Instance.new("Frame")
    titleBar.Size = UDim2.new(1, 0, 0, 40)
    titleBar.BackgroundColor3 = CurrentColors.Sidebar
    titleBar.BorderSizePixel = 0
    titleBar.ZIndex = 2
    titleBar.Parent = main
    
    if Config.Transparency then
        titleBar.BackgroundTransparency = 0.3
    end
    
    local titleText = Instance.new("TextLabel")
    titleText.Size = UDim2.new(1, -100, 1, 0)
    titleText.Position = UDim2.new(0, 15, 0, 0)
    titleText.BackgroundTransparency = 1
    titleText.Text = title or "Nova UI"
    titleText.TextColor3 = CurrentColors.Text
    titleText.TextSize = 16
    titleText.Font = Enum.Font.GothamSemibold
    titleText.TextXAlignment = Enum.TextXAlignment.Left
    titleText.ZIndex = 2
    titleText.Parent = titleBar
    
    local close = Instance.new("TextButton")
    close.Size = UDim2.new(0, 40, 0, 40)
    close.Position = UDim2.new(1, -40, 0, 0)
    close.BackgroundTransparency = 1
    close.Text = "×"
    close.TextColor3 = CurrentColors.SecondaryText
    close.TextSize = 24
    close.Font = Enum.Font.Gotham
    close.ZIndex = 2
    close.Parent = titleBar
    
    close.MouseEnter:Connect(function() Tween(close, {TextColor3 = Color3.fromRGB(255, 100, 100)}) end)
    close.MouseLeave:Connect(function() Tween(close, {TextColor3 = CurrentColors.SecondaryText}) end)
    close.MouseButton1Click:Connect(function()
        Tween(main, {Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0.5, 0)}, 0.3).Completed:Connect(function() gui:Destroy() end)
    end)
    
    local sidebar = Instance.new("Frame")
    sidebar.Size = UDim2.new(0, 140, 1, -40)
    sidebar.Position = UDim2.new(0, 0, 0, 40)
    sidebar.BackgroundColor3 = CurrentColors.Sidebar
    sidebar.BorderSizePixel = 0
    sidebar.ZIndex = 2
    sidebar.Parent = main
    
    if Config.Transparency then
        sidebar.BackgroundTransparency = 0.3
    end
    
    local divider = Instance.new("Frame")
    divider.Size = UDim2.new(0, 1, 1, 0)
    divider.Position = UDim2.new(1, 0, 0, 0)
    divider.BackgroundColor3 = CurrentColors.Border
    divider.BorderSizePixel = 0
    divider.ZIndex = 2
    divider.Parent = sidebar
    
    local content = Instance.new("Frame")
    content.Size = UDim2.new(1, -140, 1, -40)
    content.Position = UDim2.new(0, 140, 0, 40)
    content.BackgroundTransparency = 1
    content.ZIndex = 2
    content.Parent = main
    
    local dragging, dragStart, startPos
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = main.Position
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    
    local Window = {
        Gui = gui,
        Main = main,
        Sidebar = sidebar,
        Content = content,
        Tabs = {},
        ActiveTab = nil,
        BackgroundImage = bgImage,
        TitleBar = titleBar
    }
    
    NovaUI.CurrentWindow = Window
    
    -- Если есть кастомный фон, обновляем тему для контраста
    if Config.CustomBackground and Config.AutoTextColor then
        -- Даём время загрузиться фону
        task.delay(0.5, function()
            UpdateTheme(Window)
        end)
    end
    
    return Window
end

-- Create Tab
function NovaUI:CreateTab(window, name, icon)
    local id = #window.Tabs + 1
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -10, 0, 36)
    btn.Position = UDim2.new(0, 5, 0, 10 + (id - 1) * 42)
    btn.BackgroundColor3 = CurrentColors.Sidebar
    btn.BorderSizePixel = 0
    btn.Text = ""
    btn.AutoButtonColor = false
    btn.ZIndex = 2
    btn.Parent = window.Sidebar
    
    if Config.Transparency then
        btn.BackgroundTransparency = 0.3
    end
    
    Corner(btn, 6)
    
    if icon then
        local img = Instance.new("ImageLabel")
        img.Name = "Icon"
        img.Size = UDim2.new(0, 20, 0, 20)
        img.Position = UDim2.new(0, 10, 0.5, -10)
        img.BackgroundTransparency = 1
        img.Image = icon
        img.ImageColor3 = CurrentColors.SecondaryText
        img.ZIndex = 2
        img.Parent = btn
    end
    
    local txt = Instance.new("TextLabel")
    txt.Name = "Text"
    txt.Size = UDim2.new(1, icon and -40 or -20, 1, 0)
    txt.Position = UDim2.new(0, icon and 35 or 15, 0, 0)
    txt.BackgroundTransparency = 1
    txt.Text = name
    txt.TextColor3 = CurrentColors.SecondaryText
    txt.TextSize = 14
    txt.Font = Enum.Font.GothamMedium
    txt.TextXAlignment = Enum.TextXAlignment.Left
    txt.ZIndex = 2
    txt.Parent = btn
    
    local ind = Instance.new("Frame")
    ind.Name = "Indicator"
    ind.Size = UDim2.new(0, 3, 0, 0)
    ind.Position = UDim2.new(0, 0, 0.5, 0)
    ind.BackgroundColor3 = CurrentColors.Accent
    ind.BorderSizePixel = 0
    ind.ZIndex = 2
    ind.Parent = btn
    Corner(ind, 2)
    
    local tabContent = Instance.new("ScrollingFrame")
    tabContent.Name = name .. "Content"
    tabContent.Size = UDim2.new(1, 0, 1, 0)
    tabContent.BackgroundTransparency = 1
    tabContent.BorderSizePixel = 0
    tabContent.ScrollBarThickness = 4
    tabContent.ScrollBarImageColor3 = CurrentColors.Accent
    tabContent.AutomaticCanvasSize = Enum.AutomaticSize.Y
    tabContent.Visible = false
    tabContent.ZIndex = 2
    tabContent.Parent = window.Content
    
    local pad = Instance.new("UIPadding")
    pad.PaddingLeft = UDim.new(0, 15)
    pad.PaddingRight = UDim.new(0, 15)
    pad.PaddingTop = UDim.new(0, 15)
    pad.PaddingBottom = UDim.new(0, 15)
    pad.Parent = tabContent
    
    local list = Instance.new("UIListLayout")
    list.Padding = UDim.new(0, 10)
    list.Parent = tabContent
    
    local tab = {
        Button = btn,
        Content = tabContent,
        Name = name,
        Active = false
    }
    
    btn.MouseEnter:Connect(function()
        if not tab.Active then Tween(btn, {BackgroundColor3 = CurrentColors.Hover}) end
    end)
    
    btn.MouseLeave:Connect(function()
        if not tab.Active then Tween(btn, {BackgroundColor3 = CurrentColors.Sidebar}) end
    end)
    
    btn.MouseButton1Click:Connect(function() SelectTab(window, tab) end)
    
    table.insert(window.Tabs, tab)
    
    if id == 1 then task.delay(0.1, function() SelectTab(window, tab) end) end
    
    return tab
end


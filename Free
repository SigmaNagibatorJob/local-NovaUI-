local NovaUI = {}

-- Services
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- Config
local Config = {
    Size = UDim2.new(0, 500, 0, 400),
    Colors = {
        Background = Color3.fromRGB(25, 25, 25),
        Sidebar = Color3.fromRGB(30, 30, 30),
        Accent = Color3.fromRGB(0, 120, 215),
        Text = Color3.fromRGB(255, 255, 255),
        SecondaryText = Color3.fromRGB(180, 180, 180),
        Hover = Color3.fromRGB(45, 45, 45),
        Selected = Color3.fromRGB(55, 55, 55),
        Border = Color3.fromRGB(60, 60, 60)
    }
}

-- Utils
local function Tween(obj, props, dur)
    game:GetService("TweenService"):Create(obj, TweenInfo.new(dur or 0.3, Enum.EasingStyle.Quart), props):Play()
end

local function Corner(parent, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 6)
    c.Parent = parent
    return c
end

-- Select Tab
local function SelectTab(window, tab)
    if window.ActiveTab == tab then return end
    
    if window.ActiveTab then
        local prev = window.ActiveTab
        prev.Active = false
        Tween(prev.Button, {BackgroundColor3 = Config.Colors.Sidebar})
        prev.Button.Indicator.Size = UDim2.new(0, 3, 0, 0)
        
        local prevText = prev.Button:FindFirstChild("Text")
        if prevText then
            prevText.TextColor3 = Config.Colors.SecondaryText
        end
        
        if prev.Button:FindFirstChild("Icon") then
            prev.Button.Icon.ImageColor3 = Config.Colors.SecondaryText
        end
        prev.Content.Visible = false
    end
    
    tab.Active = true
    window.ActiveTab = tab
    tab.Content.Visible = true
    Tween(tab.Button, {BackgroundColor3 = Config.Colors.Selected})
    Tween(tab.Button.Indicator, {Size = UDim2.new(0, 3, 0, 20)})
    
    local tabText = tab.Button:FindFirstChild("Text")
    if tabText then
        tabText.TextColor3 = Config.Colors.Text
    end
    
    if tab.Button:FindFirstChild("Icon") then
        tab.Button.Icon.ImageColor3 = Config.Colors.Accent
    end
    tab.Content.Position = UDim2.new(0, 10, 0, 0)
    Tween(tab.Content, {Position = UDim2.new(0, 0, 0, 0)})
end

-- Create Window
function NovaUI:CreateWindow(title)
    local gui = Instance.new("ScreenGui")
    gui.Name = "NovaUI"
    gui.ResetOnSpawn = false
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    gui.Parent = player:WaitForChild("PlayerGui")
    
    local main = Instance.new("Frame")
    main.Size = Config.Size
    main.Position = UDim2.new(0.5, -250, 0.5, -200)
    main.BackgroundColor3 = Config.Colors.Background
    main.BorderSizePixel = 0
    main.ClipsDescendants = true
    main.Parent = gui
    
    Corner(main, 8)
    
    local shadow = Instance.new("ImageLabel")
    shadow.BackgroundTransparency = 1
    shadow.Image = "rbxassetid://5554236805"
    shadow.ImageColor3 = Color3.new(0, 0, 0)
    shadow.ImageTransparency = 0.6
    shadow.ScaleType = Enum.ScaleType.Slice
    shadow.SliceCenter = Rect.new(23, 23, 277, 277)
    shadow.Size = UDim2.new(1, 40, 1, 40)
    shadow.Position = UDim2.new(0, -20, 0, -20)
    shadow.ZIndex = -1
    shadow.Parent = main
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = Config.Colors.Border
    stroke.Parent = main
    
    main.Size = UDim2.new(0, 0, 0, 0)
    main.Position = UDim2.new(0.5, 0, 0.5, 0)
    Tween(main, {Size = Config.Size, Position = UDim2.new(0.5, -250, 0.5, -200)}, 0.5)
    
    local titleBar = Instance.new("Frame")
    titleBar.Size = UDim2.new(1, 0, 0, 40)
    titleBar.BackgroundColor3 = Config.Colors.Sidebar
    titleBar.BorderSizePixel = 0
    titleBar.Parent = main
    
    local titleText = Instance.new("TextLabel")
    titleText.Size = UDim2.new(1, -100, 1, 0)
    titleText.Position = UDim2.new(0, 15, 0, 0)
    titleText.BackgroundTransparency = 1
    titleText.Text = title or "Nova UI"
    titleText.TextColor3 = Config.Colors.Text
    titleText.TextSize = 16
    titleText.Font = Enum.Font.GothamSemibold
    titleText.TextXAlignment = Enum.TextXAlignment.Left
    titleText.Parent = titleBar
    
    local close = Instance.new("TextButton")
    close.Size = UDim2.new(0, 40, 0, 40)
    close.Position = UDim2.new(1, -40, 0, 0)
    close.BackgroundTransparency = 1
    close.Text = "×"
    close.TextColor3 = Config.Colors.SecondaryText
    close.TextSize = 24
    close.Font = Enum.Font.Gotham
    close.Parent = titleBar
    
    close.MouseEnter:Connect(function() Tween(close, {TextColor3 = Color3.fromRGB(255, 100, 100)}) end)
    close.MouseLeave:Connect(function() Tween(close, {TextColor3 = Config.Colors.SecondaryText}) end)
    close.MouseButton1Click:Connect(function()
        Tween(main, {Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0.5, 0)}, 0.3).Completed:Connect(function() gui:Destroy() end)
    end)
    
    local sidebar = Instance.new("Frame")
    sidebar.Size = UDim2.new(0, 140, 1, -40)
    sidebar.Position = UDim2.new(0, 0, 0, 40)
    sidebar.BackgroundColor3 = Config.Colors.Sidebar
    sidebar.BorderSizePixel = 0
    sidebar.Parent = main
    
    local divider = Instance.new("Frame")
    divider.Size = UDim2.new(0, 1, 1, 0)
    divider.Position = UDim2.new(1, 0, 0, 0)
    divider.BackgroundColor3 = Config.Colors.Border
    divider.BorderSizePixel = 0
    divider.Parent = sidebar
    
    local content = Instance.new("Frame")
    content.Size = UDim2.new(1, -140, 1, -40)
    content.Position = UDim2.new(0, 140, 0, 40)
    content.BackgroundTransparency = 1
    content.Parent = main
    
    local dragging, dragStart, startPos
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = main.Position
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    
    return {
        Gui = gui,
        Main = main,
        Sidebar = sidebar,
        Content = content,
        Tabs = {},
        ActiveTab = nil
    }
end

-- Create Tab
function NovaUI:CreateTab(window, name, icon)
    local id = #window.Tabs + 1
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -10, 0, 36)
    btn.Position = UDim2.new(0, 5, 0, 10 + (id - 1) * 42)
    btn.BackgroundColor3 = Config.Colors.Sidebar
    btn.BorderSizePixel = 0
    btn.Text = ""
    btn.AutoButtonColor = false
    btn.Parent = window.Sidebar
    
    Corner(btn, 6)
    
    if icon then
        local img = Instance.new("ImageLabel")
        img.Name = "Icon"
        img.Size = UDim2.new(0, 20, 0, 20)
        img.Position = UDim2.new(0, 10, 0.5, -10)
        img.BackgroundTransparency = 1
        img.Image = icon
        img.ImageColor3 = Config.Colors.SecondaryText
        img.Parent = btn
    end
    
    local txt = Instance.new("TextLabel")
    txt.Name = "Text"
    txt.Size = UDim2.new(1, icon and -40 or -20, 1, 0)
    txt.Position = UDim2.new(0, icon and 35 or 15, 0, 0)
    txt.BackgroundTransparency = 1
    txt.Text = name
    txt.TextColor3 = Config.Colors.SecondaryText
    txt.TextSize = 14
    txt.Font = Enum.Font.GothamMedium
    txt.TextXAlignment = Enum.TextXAlignment.Left
    txt.Parent = btn
    
    local ind = Instance.new("Frame")
    ind.Name = "Indicator"
    ind.Size = UDim2.new(0, 3, 0, 0)
    ind.Position = UDim2.new(0, 0, 0.5, 0)
    ind.BackgroundColor3 = Config.Colors.Accent
    ind.BorderSizePixel = 0
    ind.Parent = btn
    Corner(ind, 2)
    
    local tabContent = Instance.new("ScrollingFrame")
    tabContent.Name = name .. "Content"
    tabContent.Size = UDim2.new(1, 0, 1, 0)
    tabContent.BackgroundTransparency = 1
    tabContent.BorderSizePixel = 0
    tabContent.ScrollBarThickness = 4
    tabContent.ScrollBarImageColor3 = Config.Colors.Accent
    tabContent.AutomaticCanvasSize = Enum.AutomaticSize.Y
    tabContent.Visible = false
    tabContent.Parent = window.Content
    
    local pad = Instance.new("UIPadding")
    pad.PaddingLeft = UDim.new(0, 15)
    pad.PaddingRight = UDim.new(0, 15)
    pad.PaddingTop = UDim.new(0, 15)
    pad.PaddingBottom = UDim.new(0, 15)
    pad.Parent = tabContent
    
    local list = Instance.new("UIListLayout")
    list.Padding = UDim.new(0, 10)
    list.Parent = tabContent
    
    local tab = {
        Button = btn,
        Content = tabContent,
        Name = name,
        Active = false
    }
    
    btn.MouseEnter:Connect(function()
        if not tab.Active then Tween(btn, {BackgroundColor3 = Config.Colors.Hover}) end
    end)
    
    btn.MouseLeave:Connect(function()
        if not tab.Active then Tween(btn, {BackgroundColor3 = Config.Colors.Sidebar}) end
    end)
    
    btn.MouseButton1Click:Connect(function() SelectTab(window, tab) end)
    
    table.insert(window.Tabs, tab)
    
    if id == 1 then task.delay(0.1, function() SelectTab(window, tab) end) end
    
    return tab
end

-- Elements
function NovaUI:CreateButton(tab, text, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 36)
    btn.BackgroundColor3 = Config.Colors.Accent
    btn.BorderSizePixel = 0
    btn.Text = text
    btn.TextColor3 = Config.Colors.Text
    btn.TextSize = 14
    btn.Font = Enum.Font.GothamSemibold
    btn.AutoButtonColor = false
    btn.Parent = tab.Content
    
    Corner(btn, 6)
    
    btn.MouseEnter:Connect(function() Tween(btn, {BackgroundColor3 = Color3.fromRGB(0, 140, 255)}) end)
    btn.MouseLeave:Connect(function() Tween(btn, {BackgroundColor3 = Config.Colors.Accent}) end)
    btn.MouseButton1Click:Connect(callback or function() end)
    
    return btn
end

function NovaUI:CreateToggle(tab, text, default, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 40)
    frame.BackgroundColor3 = Config.Colors.Hover
    frame.BorderSizePixel = 0
    frame.Parent = tab.Content
    Corner(frame, 6)
    
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -70, 1, 0)
    lbl.Position = UDim2.new(0, 15, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = text
    lbl.TextColor3 = Config.Colors.Text
    lbl.TextSize = 14
    lbl.Font = Enum.Font.Gotham
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = frame
    
    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(0, 44, 0, 24)
    toggle.Position = UDim2.new(1, -59, 0.5, -12)
    toggle.BackgroundColor3 = default and Config.Colors.Accent or Config.Colors.Border
    toggle.BorderSizePixel = 0
    toggle.Text = ""
    toggle.AutoButtonColor = false
    toggle.Parent = frame
    Corner(toggle, 12)
    
    local circle = Instance.new("Frame")
    circle.Size = UDim2.new(0, 18, 0, 18)
    circle.Position = default and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)
    circle.BackgroundColor3 = Color3.new(1, 1, 1)
    circle.BorderSizePixel = 0
    circle.Parent = toggle
    Corner(circle, 9)
    
    local enabled = default or false
    toggle.MouseButton1Click:Connect(function()
        enabled = not enabled
        Tween(toggle, {BackgroundColor3 = enabled and Config.Colors.Accent or Config.Colors.Border})
        Tween(circle, {Position = enabled and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)})
        if callback then callback(enabled) end
    end)
    
    return frame
end

function NovaUI:CreateSlider(tab, text, min, max, default, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 60)
    frame.BackgroundColor3 = Config.Colors.Hover
    frame.BorderSizePixel = 0
    frame.Parent = tab.Content
    Corner(frame, 6)
    
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -30, 0, 20)
    lbl.Position = UDim2.new(0, 15, 0, 8)
    lbl.BackgroundTransparency = 1
    lbl.Text = text
    lbl.TextColor3 = Config.Colors.Text
    lbl.TextSize = 14
    lbl.Font = Enum.Font.Gotham
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = frame
    
    local val = Instance.new("TextLabel")
    val.Size = UDim2.new(0, 50, 0, 20)
    val.Position = UDim2.new(1, -65, 0, 8)
    val.BackgroundTransparency = 1
    val.Text = tostring(default)
    val.TextColor3 = Config.Colors.Accent
    val.TextSize = 14
    val.Font = Enum.Font.GothamBold
    val.TextXAlignment = Enum.TextXAlignment.Right
    val.Parent = frame
    
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, -30, 0, 6)
    bg.Position = UDim2.new(0, 15, 0, 38)
    bg.BackgroundColor3 = Config.Colors.Border
    bg.BorderSizePixel = 0
    bg.Parent = frame
    Corner(bg, 3)
    
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    fill.BackgroundColor3 = Config.Colors.Accent
    fill.BorderSizePixel = 0
    fill.Parent = bg
    Corner(fill, 3)
    
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.Position = UDim2.new((default - min) / (max - min), -8, 0.5, -8)
    knob.BackgroundColor3 = Color3.new(1, 1, 1)
    knob.BorderSizePixel = 0
    knob.Parent = bg
    Corner(knob, 8)
    
    local dragging = false
    local function update(input)
        local pos = math.clamp((input.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
        local value = math.floor(min + (max - min) * pos)
        fill.Size = UDim2.new(pos, 0, 1, 0)
        knob.Position = UDim2.new(pos, -8, 0.5, -8)
        val.Text = tostring(value)
        if callback then callback(value) end
    end
    
    bg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            update(input)
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then update(input) end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    
    return frame
end

function NovaUI:CreateDropdown(tab, text, options, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 40)
    frame.BackgroundColor3 = Config.Colors.Hover
    frame.BorderSizePixel = 0
    frame.ClipsDescendants = true
    frame.Parent = tab.Content
    Corner(frame, 6)
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 40)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.Parent = frame
    
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -50, 1, 0)
    lbl.Position = UDim2.new(0, 15, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = text
    lbl.TextColor3 = Config.Colors.Text
    lbl.TextSize = 14
    lbl.Font = Enum.Font.Gotham
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = btn
    
    local sel = Instance.new("TextLabel")
    sel.Size = UDim2.new(0, 100, 1, 0)
    sel.Position = UDim2.new(1, -130, 0, 0)
    sel.BackgroundTransparency = 1
    sel.Text = options[1] or "Select..."
    sel.TextColor3 = Config.Colors.SecondaryText
    sel.TextSize = 14
    sel.Font = Enum.Font.Gotham
    sel.TextXAlignment = Enum.TextXAlignment.Right
    sel.Parent = btn
    
    local arrow = Instance.new("TextLabel")
    arrow.Size = UDim2.new(0, 20, 1, 0)
    arrow.Position = UDim2.new(1, -25, 0, 0)
    arrow.BackgroundTransparency = 1
    arrow.Text = "▼"
    arrow.TextColor3 = Config.Colors.SecondaryText
    arrow.TextSize = 12
    arrow.Font = Enum.Font.Gotham
    arrow.Parent = btn
    
    local opts = Instance.new("Frame")
    opts.Size = UDim2.new(1, 0, 0, #options * 32)
    opts.Position = UDim2.new(0, 0, 0, 40)
    opts.BackgroundColor3 = Config.Colors.Hover
    opts.BorderSizePixel = 0
    opts.Visible = false
    opts.Parent = frame
    
    local expanded = false
    
    for i, opt in ipairs(options) do
        local b = Instance.new("TextButton")
        b.Size = UDim2.new(1, 0, 0, 32)
        b.Position = UDim2.new(0, 0, 0, (i-1) * 32)
        b.BackgroundTransparency = 1
        b.Text = opt
        b.TextColor3 = Config.Colors.SecondaryText
        b.TextSize = 14
        b.Font = Enum.Font.Gotham
        b.Parent = opts
        
        b.MouseEnter:Connect(function() Tween(b, {BackgroundTransparency = 0.9, BackgroundColor3 = Config.Colors.Accent}) end)
        b.MouseLeave:Connect(function() Tween(b, {BackgroundTransparency = 1}) end)
        b.MouseButton1Click:Connect(function()
            sel.Text = opt
            expanded = false
            Tween(frame, {Size = UDim2.new(1, 0, 0, 40)})
            Tween(arrow, {Rotation = 0})
            task.delay(0.2, function() opts.Visible = false end)
            if callback then callback(opt) end
        end)
    end
    
    btn.MouseButton1Click:Connect(function()
        expanded = not expanded
        if expanded then
            opts.Visible = true
            Tween(frame, {Size = UDim2.new(1, 0, 0, 40 + #options * 32)})
            Tween(arrow, {Rotation = 180})
        else
            Tween(frame, {Size = UDim2.new(1, 0, 0, 40)})
            Tween(arrow, {Rotation = 0})
            task.delay(0.2, function() opts.Visible = false end)
        end
    end)
    
    return frame
end

